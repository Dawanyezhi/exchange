<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 抑制 Logback 内部状态日志输出 -->
    <statusListener class="ch.qos.logback.core.status.NopStatusListener"/>

    <!-- 从 JVM -D 参数获取节点ID，与 cluster.sh 中的 -Dlaser.aeron.cluster.config.nodeId 保持一致 -->
    <property name="NODE_ID" value="${laser.aeron.cluster.config.nodeId:-0}" />

    <!-- 控制台输出 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 文件输出 - 每个节点独立日志文件 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${user.home}/myworkspace/java/exchange/logs/matching/matching-system-${NODE_ID}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${user.home}/myworkspace/java/exchange/logs/matching/matching-system-${NODE_ID}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 异步输出 -->
    <appender name="ASYNC" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <appender-ref ref="FILE"/>
    </appender>

    <!-- 各模块日志级别 -->
    <logger name="com.laser.exchange.matching" level="INFO"/>
    <logger name="io.aeron" level="INFO"/>
    <logger name="io.aeron.cluster" level="INFO"/>
    <logger name="io.aeron.cluster.client" level="INFO"/>
    <logger name="io.grpc" level="INFO"/>

    <!-- 根日志级别 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC"/>
    </root>

</configuration>
